{
  "mcpServers": {
    "midnight": {
      "command": "npx",
      "args": ["-y", "midnight-mcp@latest"],
      "env": {
        "MIDNIGHT_NETWORK": "preprod",
        "MIDNIGHT_NODE_URL": "wss://rpc.preprod.midnight.network",
        "MIDNIGHT_INDEXER_URL": "https://indexer.preprod.midnight.network/api/v1/graphql",
        "MIDNIGHT_INDEXER_WS_URL": "wss://indexer.preprod.midnight.network/api/v1/graphql",
        "MIDNIGHT_PROOF_SERVER_URL": "http://localhost:6300"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(vite:*)"
    ]
  }
}
